# name: test/sql/alter/alter_col/test_not_null_multi_tran.test
# description: Test Set/Drop NOT NULL in multiple transactions
# group: [alter_col]

statement ok
PRAGMA enable_verification

# Scenario #1, tran1 set not null, tran2 not able to insert
statement ok con1
CREATE TABLE t(i INTEGER, j INTEGER)


statement ok con1
BEGIN TRANSACTION

statement ok con1
insert into t values(1,1)

statement ok con1
ALTER TABLE t add primary key (i)

statement ok con2
BEGIN TRANSACTION

statement ok con2
INSERT INTO t VALUES(1,2)

statement ok con1
INSERT INTO t VALUES(7, 7)

statement ok con2
COMMIT

statement ok con1
COMMIT

query I con1
SELECT i FROM t
----
1
